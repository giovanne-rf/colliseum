# Copie este arquivo para .env para desenvolvimento local.
# No Railway, configure estas variáveis em: Project → Variables

# Ambiente
APP_ENV=production

# Banco de dados — Railway preenche DATABASE_URL automaticamente ao adicionar PostgreSQL.
# Para dev local com SQLite, use: sqlite+aiosqlite:///./colliseum.db
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Logs SQL do SQLAlchemy (true apenas para debug)
SQL_ECHO=false
